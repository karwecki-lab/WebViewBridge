use_frameworks!

target 'WebViewBridgeSample' do
  # WebViewBridge is distributed as a pre-built xcframework — no CocoaPods source needed.
  # Uncomment and update the path after building with ./gradlew :shared:assembleXCFramework
  # pod 'WebViewBridge', :path => '../shared/build/XCFrameworks/release/WebViewBridge.xcframework'
end
